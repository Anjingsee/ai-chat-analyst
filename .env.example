# Database Configuration
DATABASE_URL_MYSQL=mysql+mysql-connector-python://user:password@localhost:3306/chat_db
DATABASE_URL_PG=postgresql://user:password@localhost:5432/chat_db

# Use either MYSQL or PG
DB_TYPE=postgres

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4-turbo-preview
LLM_PROVIDER=openai

# Server Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=True

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=csv,xlsx,json,txt,pdf
